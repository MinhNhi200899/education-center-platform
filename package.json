{
  "name": "education-center-management",
  "version": "1.0.0",
  "description": "Education Center Management Platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node --transpile-only src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "deploy:db": "prisma db push",
    "test": "vitest run",
    "test:ci": "vitest run tests/unit",
    "verify": "npm run lint && npx tsc --noEmit && npm run build && npm run test:ci",
    "verify:frontend": "npm run lint --prefix frontend && npm run build --prefix frontend",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest tests/unit",
    "test:integration": "vitest tests/integration",
    "test:api": "vitest tests/api",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "cleanup:homework": "ts-node --transpile-only scripts/cleanup-homework-files.ts",
    "verify:google-drive": "ts-node --transpile-only scripts/verify-google-drive.ts",
    "setup:google-drive-oauth": "ts-node --transpile-only scripts/google-drive-oauth-setup.ts",
    "test:assign-homework": "ts-node --transpile-only scripts/test-assign-homework.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.16",
    "@types/uuid": "^9.0.8",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "googleapis": "^173.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "prisma": "^5.10.0",
    "typescript": "~6.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitest/coverage-v8": "^1.2.2",
    "eslint": "^8.57.0",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "vitest": "^1.2.2"
  },
  "overrides": {
    "tar": "^7.5.11"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "education",
    "management",
    "attendance",
    "students",
    "teachers"
  ],
  "author": "",
  "license": "ISC"
}
