# ============================================================
# Education Center Platform - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Application
NODE_ENV=production
PORT=3000

# Database - PostgreSQL
DATABASE_URL=postgresql://ecmp_user:ecmp_password@localhost:5432/ecmp_db?sslmode=prefer

# Redis
REDIS_URL=redis://localhost:6379

# JWT Configuration
# Generate secure secrets: openssl rand -base64 64
JWT_SECRET=your-jwt-secret-min-32-chars-here
JWT_EXPIRES_IN=15m

REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars-here
REFRESH_TOKEN_EXPIRES_IN=7d

# Password Reset
PASSWORD_RESET_SECRET=your-password-reset-secret-min-32-chars-here
PASSWORD_RESET_EXPIRES_IN=1h

# CORS (comma-separated) — also reads ALLOWED_ORIGINS
# Local FE :3000, production: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session
SESSION_SECRET=your-session-secret-min-32-chars-here
SESSION_MAX_AGE=86400000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# File Upload (Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@educationcenter.com

# VietQR API
VIETQR_API_KEY=your-vietqr-api-key
VIETQR_API_URL=https://api.vietqr.io

# Zalo (Optional)
ZALO_APP_ID=your-zalo-app-id
ZALO_APP_SECRET=your-zalo-app-secret

# Google Drive (session materials stub — folder for uploads)
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# Encryption
ENCRYPTION_KEY=your-32-char-encryption-key

# ============================================================
# Development-only variables (do not use in production)
# ============================================================
# DEBUG=false
# DATABASE_LOG=false